SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
PORT=3001
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated list for backend CORS checks
# CORS_ORIGINS=https://wash-and-go-front-back-*.vercel.app,http://localhost:3000
# Optional: allow any vercel.app preview origin
# CORS_ALLOW_VERCEL=false

# Brevo API (replaces Nodemailer SMTP transport)
BREVO_API_KEY=<brevo-api-key>
BREVO_BASE_URL=https://api.brevo.com
BREVO_SENDER_EMAIL=<verified-sender@yourdomain.com>
BREVO_SENDER_NAME=Wash & Go Auto Salon
BREVO_TIMEOUT_MS=15000
# Optional: set true to validate requests without sending real emails
# BREVO_SANDBOX=false

# Backward-compatible sender fallback (optional)
SMTP_FROM=<verified-sender@yourdomain.com>
SMTP_FROM_NAME=Wash & Go Auto Salon

# For Railway service variables (runtime)
# NODE_OPTIONS=--dns-result-order=ipv4first

# Comma-separated admin recipients for booking notifications
ADMIN_NOTIFICATION_EMAILS=
